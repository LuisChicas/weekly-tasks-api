{
  "name": "weekly-tasks-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node --env-file=.env.development node_modules/.bin/serverless offline",
    "deploy": "node --env-file=.env.production node_modules/.bin/serverless deploy --stage prod",
    "typecheck": "tsc --noEmit",
    "seed-flags": "node --env-file=.env.development node_modules/.bin/tsx scripts/seed-flags.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/credential-providers": "^3.995.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.3",
    "serverless-http": "^3.2.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "serverless": "^3.39.0",
    "serverless-esbuild": "^1.54.0",
    "serverless-offline": "^13.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
